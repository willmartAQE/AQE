    "email": "williammartin.aqe@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willmartAQE/AQE.git"
  },
  "license": "MIT",
  "author": "William Martin <williammartin.aqe@gmail.com>",
  "type": "module",
  "main": "./dist/AQE-light.cjs",
  "module": "./src/AQE-light.js",
  "browser": "./dist/AQE-light.min.js",
  "exports": {
    ".": {
      "import": "./src/AQE-light.js",
      "require": "./dist/AQE-light.cjs",
      "browser": "./dist/AQE-light.min.js"
    }
  },
  "files": [
