    "css-selector",
    "dom",
    "dom-query",
    "queryselector",
    "performance",
    "bitmask",
    "web-worker",
    "sharedarraybuffer",
    "bloom-filter",
    "spatial-query",
    "high-performance",
    "frontend",
    "browser"
  ],
  "homepage": "https://github.com/willmartAQE/AQE#readme",
